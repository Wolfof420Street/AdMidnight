{
  "name": "@admidnight/api",
  "version": "0.1.0",
  "scripts": {
    "predev": "node ../../scripts/ensure-compact-js-cjs.js && pnpm exec prisma generate",
    "build": "nest build",
    "dev": "nest start",
    "dev:hot": "ts-node-dev --respawn --transpile-only --ignore-watch node_modules --poll --watch src src/main.ts",
    "start:prod": "node dist/main",
    "start": "node dist/main",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema=prisma/schema.prisma",
    "seed": "prisma db seed --schema=prisma/schema.prisma",
    "test": "vitest",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0"
  },
  "prisma": {
    "seed": "node ../../scripts/seed.container.js"
  },
  "dependencies": {
    "@admidnight/midnight-sdk-wrapper": "*",
    "@admidnight/shared": "*",
    "@fastify/static": "^7.0.0",
    "@nestjs/cache-manager": "^2.2.2",
    "@nestjs/common": "^10.3.8",
    "@nestjs/config": "^3.2.2",
    "@nestjs/core": "^10.3.8",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-fastify": "^10.3.8",
    "@nestjs/swagger": "^7.3.1",
    "@nestjs/throttler": "^5.1.2",
    "@prisma/client": "^6.9.0",
    "cache-manager": "^5.4.0",
    "cache-manager-ioredis-yet": "^2.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "fastify": "^4.27.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/testing": "^10.3.8",
    "@types/node": "^20.12.7",
    "@types/uuid": "^9.0.8",
    "@vitest/coverage-v8": "^3.1.3",
    "prisma": "^6.9.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}

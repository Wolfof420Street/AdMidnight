{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "@admidnight/shared": ["../../packages/shared/dist/index.js"],
      "@admidnight/midnight-sdk-wrapper": ["../../packages/midnight-sdk-wrapper/dist/index.js"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "src/config.ts",
    "src/repositories/**/*",
    "src/services/**/*",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "src/**/*.e2e-spec.ts",
    "src/**/__tests__/**/*"
  ]
}
